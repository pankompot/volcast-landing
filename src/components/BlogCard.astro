---
import ReadingTime from './ReadingTime.astro';
import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  lang: 'en' | 'pl';
  slug: string;
  content: string;
}

const { title, description, date, tags, lang, slug, content } = Astro.props;
const dateStr = date.toLocaleDateString(lang === 'pl' ? 'pl-PL' : 'en-US', {
  year: 'numeric', month: 'short', day: 'numeric'
});
---

<a href={`/blog/${lang}/${slug}/`} class="blog-card">
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>
  <div class="card-footer">
    <span class="card-date">{dateStr}</span>
    <span class="separator">·</span>
    <ReadingTime content={content} lang={lang} />
  </div>
  <TagList tags={tags} lang={lang} linked={false} />
</a>

<style>
  .blog-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    color: inherit;
  }
  .blog-card:hover {
    border-color: var(--primary-dim);
    box-shadow: 0 0 20px var(--primary-glow);
  }
  .card-title {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .card-description {
    color: var(--text-secondary);
    font-size: 15px;
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  .separator { color: var(--divider); }
</style>
