---
interface Props {
  lang: 'en' | 'pl';
}

const { lang } = Astro.props;
---

<div class="search-wrapper" id="search" data-lang={lang}></div>

<script is:inline>
  async function initSearch() {
    var wrapper = document.getElementById('search');
    if (!wrapper) return;

    var lang = wrapper.dataset.lang;

    var pagefind = await import('/_pagefind/pagefind.js');
    await pagefind.init();

    var input = document.createElement('input');
    input.type = 'search';
    input.placeholder = lang === 'pl' ? 'Szukaj artykułów...' : 'Search articles...';
    input.className = 'search-input';

    var results = document.createElement('div');
    results.className = 'search-results';

    wrapper.appendChild(input);
    wrapper.appendChild(results);

    var debounceTimer;

    input.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(async function() {
        var query = input.value.trim();
        if (!query) {
          results.innerHTML = '';
          return;
        }

        var search = await pagefind.search(query);
        var items = await Promise.all(search.results.slice(0, 8).map(function(r) { return r.data(); }));

        items.sort(function(a, b) {
          var aLang = a.meta?.lang || '';
          var bLang = b.meta?.lang || '';
          if (aLang === lang && bLang !== lang) return -1;
          if (bLang === lang && aLang !== lang) return 1;
          return 0;
        });

        results.innerHTML = items.map(function(item) {
          return '<a href="' + item.url + '" class="search-result">' +
            '<span class="result-title">' + (item.meta?.title || item.url) + '</span>' +
            '<span class="result-excerpt">' + item.excerpt + '</span>' +
          '</a>';
        }).join('');
      }, 200);
    });
  }

  initSearch();
</script>

<style>
  .search-wrapper { position: relative; margin-bottom: 2rem; }
  .search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 16px;
    font-family: 'DM Sans', sans-serif;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .search-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-glow); }
  .search-input::placeholder { color: var(--text-muted); }
  .search-results {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    max-height: 400px;
    overflow-y: auto;
    z-index: 50;
  }
  .search-results:empty { display: none; }
  .search-result {
    display: block;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--surface-border);
    transition: background 0.2s ease;
  }
  .search-result:last-child { border-bottom: none; }
  .search-result:hover { background: var(--primary-glow); }
  .result-title {
    display: block;
    color: var(--text-primary);
    font-weight: 500;
    font-size: 15px;
    margin-bottom: 0.25rem;
  }
  .result-excerpt {
    display: block;
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.4;
  }
  .result-excerpt :global(mark) {
    background: var(--primary-glow-strong);
    color: var(--primary);
  }
</style>
