---
interface Props {
  lang: 'en' | 'pl';
}

const { lang } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <div class="footer-links">
        <a href={`/${lang}/`}>Home</a>
        <a href={`/blog/${lang}/`}>Blog</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
      <p class="footer-brand">
        A <strong>Volter Labs</strong> product
      </p>
    </div>
    <div class="footer-badges">
      <a href="https://play.google.com/store/apps/details?id=com.volcast.app" target="_blank" rel="noopener" class="store-badge" aria-label="Google Play">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/></svg>
        <div class="store-badge-text">
          <small>{lang === 'pl' ? 'Pobierz z' : 'Get it on'}</small>
          <span>Google Play</span>
        </div>
      </a>
      <span class="store-badge store-badge--disabled" aria-label="App Store — Coming soon">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.71,19.5C17.88,20.5 17,21.4 15.66,21.41C14.32,21.42 13.87,20.57 12.37,20.57C10.87,20.57 10.37,21.37 9.1,21.41C7.79,21.46 6.8,20.4 5.96,19.39C4.25,17.35 2.94,13.69 4.72,11.23C5.6,9.99 6.94,9.21 8.39,9.2C9.65,9.18 10.85,10.12 11.59,10.12C12.34,10.12 13.78,8.99 15.28,9.15C15.91,9.18 17.51,9.41 18.5,10.87C18.41,10.93 16.4,12.11 16.43,14.57C16.46,17.51 19,18.41 19.03,18.42C19,18.5 18.71,19.5 18.71,19.5M13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z"/></svg>
        <div class="store-badge-text">
          <small>Coming soon</small>
          <span>App Store</span>
        </div>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--surface-border);
    padding: 2rem 1.5rem;
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-left { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    color: var(--text-muted);
    font-size: 14px;
  }
  .footer-links a:hover { color: var(--text-secondary); }
  .footer-brand {
    color: var(--text-muted);
    font-size: 14px;
  }
  .footer-brand strong { color: var(--text-secondary); }
  .footer-badges {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .store-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.8rem;
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 14px;
    transition: border-color 0.2s ease;
  }
  a.store-badge:hover { border-color: var(--primary-dim); color: var(--text-primary); }
  .store-badge--disabled {
    opacity: 0.5;
    cursor: default;
  }
  .store-badge-text { display: flex; flex-direction: column; line-height: 1.2; }
  .store-badge-text small { font-size: 10px; color: var(--text-muted); }
  .store-badge-text span { font-size: 13px; font-weight: 500; }

  @media (max-width: 640px) {
    .footer-inner { flex-direction: column; gap: 1.5rem; text-align: center; }
    .footer-badges { justify-content: center; }
  }
</style>
