---
interface Props {
  content: string;
  lang: 'en' | 'pl';
}

const { content, lang } = Astro.props;
const words = content.trim().split(/\s+/).length;
const wpm = lang === 'pl' ? 180 : 200;
const minutes = Math.max(1, Math.round(words / wpm));
const label = lang === 'pl' ? `${minutes} min czytania` : `${minutes} min read`;
---

<span class="reading-time">{label}</span>

<style>
  .reading-time { color: var(--text-muted); font-size: 14px; }
</style>
