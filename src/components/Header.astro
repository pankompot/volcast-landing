---
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: 'en' | 'pl';
  translationUrl?: string;
  activePage?: 'home' | 'blog';
}

const { lang, translationUrl, activePage = 'blog' } = Astro.props;
---

<header class="site-header">
  <div class="header-inner">
    <a href={`/${lang}/`} class="logo" aria-label="Volcast home">
      <svg viewBox="0 0 80 80" fill="none" width="28" height="28">
        <path d="M18 18 L40 62 L62 18" stroke="#00FF9D" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="40" cy="12" r="4" fill="#00FF9D"/>
      </svg>
      <span>Volcast</span>
    </a>

    <nav class="nav-links">
      <a href={`/${lang}/`} class={activePage === 'home' ? 'active' : ''}>Home</a>
      <a href={`/blog/${lang}/`} class={activePage === 'blog' ? 'active' : ''}>Blog</a>
    </nav>

    <LanguageSwitcher lang={lang} translationUrl={translationUrl} />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--surface);
    border-bottom: 1px solid var(--surface-border);
    backdrop-filter: blur(12px);
  }
  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 18px;
  }
  .logo:hover { color: var(--primary); }
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  .nav-links a {
    color: var(--text-secondary);
    font-size: 15px;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .nav-links a:hover { color: var(--text-primary); }
  .nav-links a.active { color: var(--primary); }

  @media (max-width: 640px) {
    .header-inner { padding: 0.75rem 1rem; }
    .nav-links { gap: 1rem; }
  }
</style>
